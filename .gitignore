# Rust build artifacts
/target
**/*.rs.bk

# Cargo.lock IS committed for this workspace (reproducible builds, NFR7).
# Do NOT add Cargo.lock here.

# Tool output — never commit triage results (incl. live-run dirs like out-live/).
# Live runs capture real host process/network state; these must never be committed.
/out
/out-*
/test-data

# Forensic fixtures & sample evidence — kept out of git (size + sensitivity).
# EVTX-ATTACK-SAMPLES is fetched by a script into tests/ (stage1-plan T8), not committed.
*.evtx
*.zip
*.hve
*.dat
*.bad
/tests/samples/
/tests/fixtures/
/tests/EVTX-ATTACK-SAMPLES/

# Decoded plain rules (the encoded form is the bundled one; ADR-0002)
/rules/plain/

# Machine-specific cargo config (absolute target-dir outside OneDrive — per-machine).
# Set CARGO_TARGET_DIR or recreate .cargo/config.toml locally; see CLAUDE.md dev notes.
/.cargo/config.toml

# OS / editor
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/
*.swp

# Local debug artifacts — real host prefetch files, never commit
*.pf
sample.pf
